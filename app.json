{
  "expo": {
    "name": "NodoX App",
    "slug": "nodox-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nodox",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.nodox.app",
      "infoPlist": {
        "NSCameraUsageDescription": "NodoX necesita acceso a tu cámara para subir fotos de productos y escanear códigos QR.",
        "NSMicrophoneUsageDescription": "NodoX necesita acceso al micrófono para grabar notas de voz en el chat.",
        "NSPhotoLibraryUsageDescription": "NodoX necesita acceso a tu galería para subir fotos de perfil y productos.",
        "UIBackgroundModes": [
          "audio",
          "remote-notification"
        ]
      },
      "entitlements": {
        "com.apple.developer.networking.wifi-info": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "co.nodox.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_MEDIA_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://nodox.co"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permite a NodoX usar la cámara.",
          "microphonePermission": "Permite a NodoX usar el micrófono."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite a NodoX acceder a tus fotos."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.co.nodox.app",
          "enableGooglePay": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-project-id-here"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
